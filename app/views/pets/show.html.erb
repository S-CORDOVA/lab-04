<h1><%= @pet.name %></h1>

<p>Species: <%= @pet.species %></p>
<p>Breed: <%= @pet.breed %></p>
<p>Date of birth: <%= formatted_date(@pet.date_of_birth) %>
<p>Weight: <%= @pet.weight %></p>

<p>
  Owner:
  <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", owner_path(@pet.owner) %>
</p>

<h2>Appointments</h2>

<ul>
  <% @pet.appointments.each do |appointment| %>
    <li>
      <%= link_to "#{formatted_datetime(appointment.date)} - #{appointment.reason}", appointment_path(appointment) %>
    </li>
  <% end %>
</ul>

<%= link_to "Back", pets_path %>