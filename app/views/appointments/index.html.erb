<h1>Appointments</h1>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Date</th>
      <th>Pet name</th>
      <th>Vet name</th>
      <th>Reason</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td><%= link_to formatted_datetime(appointment.date), appointment_path(appointment) %></td>
        <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
        <td><%= link_to "#{appointment.vet.first_name} #{appointment.vet.last_name}", vet_path(appointment.vet) %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment_status_text(appointment.status) %></td>
      </tr>
    <% end %>
  </tbody>
</table>